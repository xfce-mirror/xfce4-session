#: xfce4-session/xfsm-chooser.c:144
msgid "Session Manager"
msgstr "ຕົວຈັດການວາລະ"

#: xfce4-session/xfsm-chooser.c:175
msgid ""
"Choose the session you want to restore. You can simply double-click the "
"session name to restore it."
msgstr "ເລືອກວາລະທີ່ທ່ານຕ້ອງການກູ້ຄືນ. ທ່ານພຽງແຕ່ດັບເບີ້ນຄລິກທີ່ຊື່ວາລະເພື່ອມີການກູ້ຄືນ."

#: xfce4-session/xfsm-chooser.c:191
msgid "Create a new session."
msgstr "ສ້າງວາລະໃໝ່."

#: xfce4-session/xfsm-chooser.c:198
msgid "Delete a saved session."
msgstr "ລຶບວາລະທີ່ບັນທຶກໄວ້."

#. "Logout" button
#: xfce4-session/xfsm-chooser.c:209
#: xfce4-session-logout/xfce4-session-logout.desktop.in:12
msgid "Log Out"
msgstr "ອອກຈາກລະບົບ"

#: xfce4-session/xfsm-chooser.c:211
msgid "Cancel the login attempt and return to the login screen."
msgstr "ຍົກເລີກການພະຍາຍາມເຂົ້າລະບົບ ແລະ ກັບຄືນສູ່ໜ້າຈໍເຂົ້າລະບົບ."

#. "Start" button
#: xfce4-session/xfsm-chooser.c:218
msgid "Start"
msgstr "ເລີ່ມ"

#: xfce4-session/xfsm-chooser.c:219
msgid "Start an existing session."
msgstr "ເລີ່ມວາລະທີ່ມີຢູ່."

#: xfce4-session/xfsm-dns.c:73
msgid "(Unknown)"
msgstr "(ບໍ່ຮູ້ຈັກ)"

#: xfce4-session/xfsm-dns.c:146
#, c-format
msgid ""
"Could not look up internet address for %s.\n"
"This will prevent Xfce from operating correctly.\n"
"It may be possible to correct the problem by adding\n"
"%s to the file /etc/hosts on your system."
msgstr "ບໍ່ສາມາດຊອກຫາທີ່ຢູ່ອິນເຕີເນັດສຳລັບ %s.\nນີ້ຈະເຮັດໃຫ້ Xfce ເຮັດວຽກບໍ່ຖືກຕ້ອງ.\nທ່ານອາດຈະແກ້ໄຂບັນຫາໄດ້ໂດຍການເພີ່ມ\n%s ເຂົ້າໃນໄຟລ໌ /etc/hosts ໃນລະບົບຂອງທ່ານ."

#: xfce4-session/xfsm-dns.c:152
msgid "Continue anyway"
msgstr "ດຳເນີນການຕໍ່ຕໍ່ໄປ"

#: xfce4-session/xfsm-dns.c:153
msgid "Try again"
msgstr "ລອງໃໝ່"

#: xfce4-session/xfsm-manager.c:592
#, c-format
msgid ""
"Unable to determine failsafe session name.  Possible causes: xfconfd isn't "
"running (D-Bus setup problem); environment variable $XDG_CONFIG_DIRS is set "
"incorrectly (must include \"%s\"), or xfce4-session is installed "
"incorrectly."
msgstr "ບໍ່ສາມາດກຳນົດຊື່ວາລະ failsafe ໄດ້. ສາເຫດທີ່ເປັນໄປໄດ້: xfconfd ບໍ່ໄດ້ເຮັດວຽກ (ບັນຫາການຕັ້ງຄ່າ D-Bus); ຕົວປ່ຽນສະພາບແວດລ້ອມ $XDG_CONFIG_DIRS ຖືກຕັ້ງຄ່າບໍ່ຖືກຕ້ອງ (ຕ້ອງລວມມີ \"%s\"), ຫຼື xfce4-session ຖືກຕິດຕັ້ງບໍ່ຖືກຕ້ອງ."

#: xfce4-session/xfsm-manager.c:617
#, c-format
msgid ""
"The specified failsafe session (\"%s\") is not marked as a failsafe session."
msgstr "ວາລະ failsafe ທີ່ລະບຸ (\"%s\") ບໍ່ໄດ້ຖືກໝາຍວ່າເປັນວາລະ failsafe."

#: xfce4-session/xfsm-manager.c:656
msgid "The list of applications in the failsafe session is empty."
msgstr "ລາຍຊື່ແອັບພລິເຄຊັນໃນວາລະ failsafe ວ່າງເປົ່າ."

#: xfce4-session/xfsm-manager.c:740
msgid "Name for the new session"
msgstr "ຊື່ສຳລັບວາລະໃໝ່"

#. FIXME: migrate this into the splash screen somehow so the
#. * window doesn't look ugly (right now no WM is running, so it
#. * won't have window decorations).
