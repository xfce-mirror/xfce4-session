#: ../xfce.desktop.in.h:1
msgid "Xfce Session"
msgstr "ວາລະ Xfce"

#: ../xfce.desktop.in.h:2
msgid "Use this session to run Xfce as your desktop environment"
msgstr "ໃຊ້ວາລະນີ້ເພື່ອແລ່ນ Xfce ເປັນສະພາບແວດລ້ອມເດັສທັອບຂອງທ່ານ"

