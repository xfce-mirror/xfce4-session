#, c-format
msgid "Type '%s --help' for usage."
msgstr "ພິມ '%s --help' ສຳລັບວິທີໃຊ້."

#: settings/main.c:129 xfce4-session/main.c:373
#: xfce4-session-logout/main.c:121
