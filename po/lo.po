#: xfce.desktop.in:4
msgid "Xfce Session"
msgstr "ວາລະ Xfce"

#: xfce.desktop.in:5 xfce-wayland.desktop.in:5
msgid "Use this session to run Xfce as your desktop environment"
msgstr "ໃຊ້ວາລະນີ້ເພື່ອແລ່ນ Xfce ເປັນສະພາບແວດລ້ອມເດັສທັອບຂອງທ່ານ"

#: xfce.desktop.in:10
msgid "xfce;session;desktop;environment;window manager;gui;"
msgstr "xfce;ວາລະ;ເດັສທັອບ;ສະພາບແວດລ້ອມ;ຕົວຈັດການປ່ອງຢ້ຽມ;gui;"

#: xfce-wayland.desktop.in:4
msgid "Xfce Session (Wayland)"
msgstr "ວາລະ Xfce (Wayland)"

#: xfce-wayland.desktop.in:10
msgid "xfce;wayland;desktop;environment;session;"
msgstr "xfce;wayland;ເດັສທັອບ;ສະພາບແວດລ້ອມ;ວາລະ;"

