#, c-format
msgid "You might need to delete some files manually in \"%s\"."
msgstr "ທ່ານອາດຈະຕ້ອງໄດ້ລຶບບາງໄຟລ໌ດ້ວຍຕົນເອງໃນ \"%s\"."

#: ../settings/session-editor.c:245
msgid "All Xfce cache files could not be cleared"
msgstr "ບໍ່ສາມາດລ້າງໄຟລ໌ແຄຊ໌ Xfce ທັງໝົດໄດ້"

#: ../settings/session-editor.c:284
#, c-format
msgid "Are you sure you want to terminate \"%s\"?"
msgstr "ທ່ານແນ່ໃຈບໍ່ວ່າຕ້ອງການຢຸດການເຮັດວຽກຂອງ \"%s\"?"

#: ../settings/session-editor.c:287 ../settings/session-editor.c:312
msgid "Terminate Program"
msgstr "ຢຸດໂຄງການ"

#: ../settings/session-editor.c:289
msgid ""
"The application will lose any unsaved state and will not be restarted in "
"your next session."
msgstr ""
"ແອັບພລິເຄຊັນຈະສູນເສຍສະຖານະທີ່ບໍ່ໄດ້ບັນທຶກ ແລະ "
"ຈະບໍ່ຖືກເລີ່ມໃໝ່ໃນວາລະຕໍ່ໄປຂອງທ່ານ."

