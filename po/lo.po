#: xfce4-session/xfsm-manager.c:1327 settings/xfce4-session-settings.ui:95
msgid "_Close"
msgstr "_ປິດ"

#: settings/session-editor.c:191
msgid ""
"The saved states of your applications will not be restored during your next "
"login."
msgstr "ສະຖານະທີ່ບັນທຶກໄວ້ຂອງແອັບພລິເຄຊັນຂອງທ່ານຈະບໍ່ຖືກກູ້ຄືນໃນການເຂົ້າລະບົບຄັ້ງຕໍ່ໄປ."

#: settings/session-editor.c:196
msgid "Clear sessions"
msgstr "ລ້າງວາລະ"

#: settings/session-editor.c:197
msgid "Are you sure you want to empty the session cache?"
msgstr "ທ່ານແນ່ໃຈບໍ່ວ່າຕ້ອງການລ້າງແຄຊ໌ຂອງວາລະ?"

#: settings/session-editor.c:198 settings/session-editor.c:290
#: settings/xfae-dialog.c:75 xfce4-session/xfsm-manager.c:727
#: xfce4-session/xfsm-logout-dialog.c:227
msgid "_Cancel"
msgstr "_ຍົກເລີກ"

#: settings/session-editor.c:198
msgid "_Proceed"
msgstr "_ດຳເນີນການຕໍ່"

#: settings/session-editor.c:242
#, c-format
msgid "You might need to delete some files manually in \"%s\"."
msgstr "ທ່ານອາດຈະຕ້ອງໄດ້ລຶບບາງໄຟລ໌ດ້ວຍຕົນເອງໃນ \"%s\"."

#: settings/session-editor.c:245
msgid "All Xfce cache files could not be cleared"
msgstr "ບໍ່ສາມາດລ້າງໄຟລ໌ແຄຊ໌ Xfce ທັງໝົດໄດ້"

#: settings/session-editor.c:286
#, c-format
msgid "Are you sure you want to terminate \"%s\"?"
msgstr "ທ່ານແນ່ໃຈບໍ່ວ່າຕ້ອງການຢຸດການເຮັດວຽກຂອງ \"%s\"?"

#: settings/session-editor.c:287
msgid ""
"The application will lose any unsaved state and will not be restarted in "
"your next session."
msgstr "ແອັບພລິເຄຊັນຈະສູນເສຍສະຖານະທີ່ບໍ່ໄດ້ບັນທຶກ ແລະ ຈະບໍ່ຖືກເລີ່ມໃໝ່ໃນວາລະຕໍ່ໄປຂອງທ່ານ."

